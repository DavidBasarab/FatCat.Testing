# Auto detect text files and perform LF normalization
* text=auto

# C# source files
*.cs text eol=lf
*.csx text eol=lf

# Config / project files
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.config text eol=lf
*.editorconfig text eol=lf

# Scripts
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.cmd text eol=lf

# Web / markup
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
